# Defaults for the Nova SBE alumni networker agent.
# Installed to /etc/default/alumni-agent by ops/install.sh.

REPO_DIR=/home/alumni/NovaAlumniConnect
GIT_REMOTE=origin
GIT_BRANCH=main

# Model: Claude Haiku 4.5 is fast and cheap, ideal for a frequent cron loop.
MODEL_ID=claude-haiku-4.5

# Reasoning effort: low is the right default for a small matching task on
# fewer than ~200 profiles. Bump to medium if the network grows past that.
EFFORT=low

# Set FORCE_RUN=1 here (or in a one-off run) to bypass the
# "profiles unchanged" short circuit. Useful after editing the prompt.
FORCE_RUN=0

STATE_DIR=/home/alumni/.local/state/alumni-agent
AGENT_GIT_NAME=nova-networker-bot
AGENT_GIT_EMAIL=bot@novasbealumni.com
